{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --env-file --allow-read --allow-write main.ts",
    "start": "deno run --allow-net --allow-env --env-file --allow-read --allow-write main.ts",
    "test": "deno run --allow-net --allow-env --env-file --allow-read --allow-write main.ts test",
    "pr-test": "deno run --allow-net --allow-env --env-file --allow-read --allow-write main.ts pr-test",
    "pr-preview": "deno run --allow-net --allow-env --env-file --allow-read main.ts pr-preview --preview"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "deploy": {
    "project": "google-chat-standup",
    "entrypoint": "main.ts"
  },
  "crons": [
    {
      "name": "daily-standup",
      "schedule": "0 3 * * *"
    },
    {
      "name": "pr-reminder",
      "schedule": "0 1 * * *"
    }
  ]
}
